# ══════════════════════════════════════════════════════════════════
# BEACON PROTOCOL — Variables de Entorno (PLANTILLA)
# ══════════════════════════════════════════════════════════════════
# Copia este archivo como .env y rellena con valores reales:
#   cp .env.example .env
#
# NUNCA commitees el archivo .env real. Está en .gitignore.
# ══════════════════════════════════════════════════════════════════


# ─── Supabase ──────────────────────────────────────────────────
# URL del proyecto Supabase (visible en Settings → API)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anon (pública, frontend-safe)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon-key-aqui

# Clave service_role (NUNCA exponer al frontend ni en logs)
# Se usa exclusivamente en el backend para operaciones privilegiadas.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service-role-aqui


# ─── Base de Datos ─────────────────────────────────────────────
# Cadena de conexión directa a PostgreSQL (Supabase → Settings → Database)
# Formato: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:tu-password@db.tu-proyecto.supabase.co:5432/postgres


# ─── Redis ─────────────────────────────────────────────────────
# URL de conexión a Redis (El Demonio de la Pre-gestión).
# En local: redis://localhost:6379/0
# En producción: usa Upstash, Railway u otro proveedor.
REDIS_URL=redis://localhost:6379/0


# ─── JWT (The Vault) ───────────────────────────────────────────
# Clave secreta para firmar tokens JWT.
# REQUERIDO: mínimo 32 caracteres.
# Genera una clave fuerte:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REEMPLAZA-CON-CLAVE-ALEATORIA-DE-AL-MENOS-32-CHARS

# Algoritmo de firma (no cambiar salvo decisión arquitectural)
JWT_ALGORITHM=HS256

# Expiración del token en minutos (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ─── Salt Forense del RUT ──────────────────────────────────────
# Salt para SHA-256 del RUT chileno. REQUERIDO, sin default.
# MÍNIMO 16 caracteres.
#
# ⚠️  ADVERTENCIA CRÍTICA: Si cambias este valor en producción,
#     todos los rut_hash existentes quedan HUÉRFANOS y los usuarios
#     deberán re-verificar su identidad. Trata esta salt como
#     una clave maestra: establécela una vez y no la toques.
#
# Genera una salt segura:
#   python -c "import secrets; print(secrets.token_hex(16))"
RUT_HASH_SALT=REEMPLAZA-CON-SALT-ALEATORIA-DE-AL-MENOS-16-CHARS


# ─── Aplicación ────────────────────────────────────────────────
# Modo debug: muestra /docs y /redoc. NUNCA activar en producción.
DEBUG=false

# Nombre y versión (usados en los logs y en el header de la API)
APP_NAME=Beacon Protocol
APP_VERSION=0.1.0

# Prefijo de la API REST
API_V1_PREFIX=/api/v1


# ─── CORS ──────────────────────────────────────────────────────
# Orígenes permitidos para el frontend (lista separada por comas).
# En producción reemplaza con el dominio real del frontend.
# Ejemplo producción: CORS_ORIGINS=["https://beacon.cl"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]


# ─── Notificaciones Admin (Bell) ───────────────────────────────
# Opcional: sin estas vars el sistema funciona igual (solo audit_log, sin email).
# Puerto 465 → SSL directo (SMTP_SSL).  Puerto 587 → STARTTLS.
ADMIN_EMAIL=admin@beaconchile.cl
SMTP_HOST=mail.beaconchile.cl
SMTP_PORT=465
SMTP_USER=admin@beaconchile.cl
SMTP_PASSWORD=TU_PASSWORD_SMTP_AQUI
