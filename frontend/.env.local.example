# ══════════════════════════════════════════════════════════════════
# BEACON PROTOCOL — Variables de Entorno Frontend (PLANTILLA)
# ══════════════════════════════════════════════════════════════════
# Copia este archivo como .env.local y rellena con valores reales:
#   cp .env.local.example .env.local
#
# NUNCA commitees .env.local. Está en .gitignore.
# ══════════════════════════════════════════════════════════════════

# ─── URL del backend FastAPI ───────────────────────────────────────
# En desarrollo local: http://localhost:8000
# En producción: URL de tu deploy (Railway, Fly.io, etc.)
#
# ⚠️  Si esta variable no está definida, el frontend apunta a
#     http://localhost:8000 por defecto (ver src/app/page.tsx).
#     En producción esto produce errores silenciosos.
NEXT_PUBLIC_API_URL=http://localhost:8000
